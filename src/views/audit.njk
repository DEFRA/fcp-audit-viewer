{% extends "layout.njk" %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block content %}
  <div data-testid="app-page-body">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-l">Farming audit events</h1>

        {% if summary is null or summary is not defined %}
          <p class="govuk-body">Summary data unavailable.</p>
        {% else %}
          <p class="govuk-body">
            <a href="/query" class="govuk-link">Query builder</a>
          </p>
        {% endif %}
      </div>
    </div>

    {% if summary is not null and summary is defined %}
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
          {{ govukSummaryList({
            card: {
              title: { text: "Summary" }
            },
            rows: [
              {
                key: { text: "Total events" },
                value: { text: summary.total, classes: "govuk-!-text-align-right" },
                actions: {
                  items: [
                    {
                      href: "/results",
                      text: "View",
                      visuallyHiddenText: "all audit events"
                    }
                  ]
                }
              }
            ]
          }) }}
        </div>
      </div>

      <div class="govuk-grid-row">
        {% for application in summary.applications | sort(true, false, "total") %}
          <div class="govuk-grid-column-full">
            {% set applicationHref = "/results?application=" + (application.application | urlencode) %}
            {% set appRows = [
              {
                key: { text: "Total events" },
                value: { text: application.total, classes: "govuk-!-text-align-right" },
                actions: {
                  items: [
                    {
                      href: applicationHref,
                      text: "View",
                      visuallyHiddenText: "all events for " + application.application
                    }
                  ]
                }
              }
            ] %}
            {% for component in application.components %}
              {% set componentHref = applicationHref + "&component=" + (component.component | urlencode) %}
              {% set _ = appRows.push({
                key: { text: component.component },
                value: { text: component.total, classes: "govuk-!-text-align-right" },
                actions: {
                  items: [
                    {
                      href: componentHref,
                      text: "View",
                      visuallyHiddenText: "events for " + component.component + " in " + application.application
                    }
                  ]
                }
              }) %}
            {% endfor %}
            {{ govukSummaryList({
              card: {
                title: { text: application.application }
              },
              rows: appRows
            }) }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
{% endblock %}
